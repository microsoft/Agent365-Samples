<?xml version="1.0" encoding="UTF-8"?>
<!--
  External Credential holding the FMI sponsor (agent blueprint app) client secret.

  Custom auth protocol: the token POSTs are hand-rolled in A365ObsToken (Apex), so this does NOT
  use Salesforce's built-in OAuth client-credentials flow (it can't add fmi_path or do the
  JWT-bearer Hop 3).

  SECRET IS NOT IN GIT. After deploy, in Setup -> Named Credentials -> External Credentials
  -> "A365 Obs Entra" -> Principals -> edit "BlueprintPrincipal" and add a custom
  Authentication Parameter:
      Name  = BlueprintBasicAuth
      Value = base64("<<AGENT_BLUEPRINT_ID>>:<blueprint-client-secret>")
  The blueprint app is the FMI sponsor for the agent (the AgentId__c in
  A365_Observability_Config.Default). Compute the Basic value (strip any trailing CR):
      printf '%s' '<<AGENT_BLUEPRINT_ID>>:<secret>' | base64 -w0
-->
<ExternalCredential xmlns="http://soap.sforce.com/2006/04/metadata">
    <label>A365 Obs Entra</label>
    <authenticationProtocol>Custom</authenticationProtocol>
    <externalCredentialParameters>
        <parameterName>BlueprintPrincipal</parameterName>
        <parameterType>NamedPrincipal</parameterType>
        <sequenceNumber>1</sequenceNumber>
    </externalCredentialParameters>
</ExternalCredential>
