<?xml version="1.0" encoding="UTF-8"?>
<!--
  Named Credential targeted by A365Callout.cls (callout:A365_Callback).
  The <endpoint> below is a PLACEHOLDER. Set it to your public HTTPS base URL that forwards
  to the A365 agent's /callback (e.g. a dev tunnel in front of the agent on port 3978):

      Setup -> Named Credentials -> "A365 Callback" -> edit URL
      (or: sf project deploy after editing the <endpoint> locally)

  Do not commit your live tunnel URL.
-->
<NamedCredential xmlns="http://soap.sforce.com/2006/04/metadata">
    <label>A365 Callback</label>
    <endpoint>https://REPLACE-WITH-YOUR-TUNNEL-URL.devtunnels.ms</endpoint>
    <generateAuthorizationHeader>false</generateAuthorizationHeader>
    <principalType>Anonymous</principalType>
    <protocol>NoAuthentication</protocol>
</NamedCredential>
