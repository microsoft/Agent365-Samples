{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Start Agents Playground",
      "type": "shell",
      "command": "npm run dev:teamsfx:launch-playground",
      "isBackground": true,
      "problemMatcher": {
        "pattern": {
          "regexp": "^.*$",
          "file": 0,
          "location": 1,
          "message": 2
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".",
          "endsPattern": "."
        }
      }
    }
  ]
}
