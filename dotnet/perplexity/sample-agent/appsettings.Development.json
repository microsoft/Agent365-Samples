          "https://api.botframework.com/.default"
        ]
      }
    }
  },
  "AIServices": {
    "Perplexity": {
      "Endpoint": "https://api.perplexity.ai/v1",
      "ApiKey": "----",
      "Model": "perplexity/sonar"
    }
  }
}
