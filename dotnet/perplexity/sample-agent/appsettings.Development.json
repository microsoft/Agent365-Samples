{
  "TokenValidation": {
    "Enabled": false,
    "Audiences": [
      "{{ClientId}}"
    ],
    "TenantId": "{{TenantId}}"
  },
  "Connections": {
    "ServiceConnection": {
      "Settings": {
        "AuthType": "ClientSecret",
        "ClientId": "{{ClientId}}",
        "ClientSecret": "----",
        "AuthorityEndpoint": "https://login.microsoftonline.com/{{TenantId}}",
