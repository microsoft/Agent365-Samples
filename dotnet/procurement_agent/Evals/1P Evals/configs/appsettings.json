{
  "AgentSettings": {
    "Type": "LocalAgent"
  },
  "AiSettings": {
    "Provider": "AzureOpenAI",
    "Endpoint": "https://your-resource.openai.azure.com/",
    "ModelName": "gpt-4",
    "UseDefaultAzureCredential": true,
    "MaxTokens": 1000,
    "Temperature": 0.7,
    "TimeoutSeconds": 30,
    "MaxRetries": 3
  },
  "ReportSettings": {
    "OutputDirectory": "./reports",
    "Formats": [
      "Excel",
      "JSON"
    ],
    "IncludeDetailedResults": true,
    "IncludeCharts": true
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "LocalEvalTool": "Debug"
    }
  }
}
