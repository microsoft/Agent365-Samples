## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.

# User-specific files
*.suo
*.user
*.userosscache
*.sln.docstates

# Build results
[Dd]ebug/
[Rr]elease/
x64/
x86/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/

# Visual Studio cache/options directory
.vs/

# NuGet Packages
*.nupkg
**/packages/*
*.nuget.props
*.nuget.targets

# Misc
*.swp
*.*~
project.lock.json
.DS_Store
*.pdf

# User secrets
secrets.json

# Environment files
.env

# A365 CLI generated config (contains secrets)
a365.config.json
a365.generated.config.json

# Azure exported settings (contains secrets)
azure-appsettings.json

# Deployment artifacts
app.zip
publish/
manifest/manifest.zip

# Runtime logs
log.txt
*.log
webapp-logs*/
webapp-logs*.zip

# Emulator transcripts
emulator/

# DevTools logs
devTools/*.log

# Temporary JSON files
role-grant*.json
scope-update*.json
required-access.json

# Playground config (with real secrets — the template in repo uses "---" placeholders)
# appsettings.Playground.json
