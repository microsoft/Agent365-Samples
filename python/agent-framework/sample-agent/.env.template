# =============================================================================
# Azure OpenAI Configuration
# =============================================================================
AZURE_OPENAI_ENDPOINT=<<YOUR_AZURE_OPENAI_ENDPOINT>>
AZURE_OPENAI_DEPLOYMENT=<<YOUR_DEPLOYMENT_NAME>>
AZURE_OPENAI_API_KEY=<<YOUR_API_KEY>>
# AZURE_OPENAI_API_VERSION — Optional. Omit to use the SDK default (v1 Responses API).
# Only set this if your deployment requires a specific dated API version.
# AZURE_OPENAI_API_VERSION=

# =============================================================================
# Agent 365 Service Connection (stamped by 'a365 setup all')
# =============================================================================
AGENT_ID=<<YOUR_BLUEPRINT_ID>>
CONNECTIONS__SERVICE_CONNECTION__SETTINGS__CLIENTID=<<YOUR_BLUEPRINT_ID>>
CONNECTIONS__SERVICE_CONNECTION__SETTINGS__CLIENTSECRET=<<YOUR_CLIENT_SECRET>>
CONNECTIONS__SERVICE_CONNECTION__SETTINGS__TENANTID=<<YOUR_TENANT_ID>>
CONNECTIONS__SERVICE_CONNECTION__SETTINGS__SCOPES=5a807f24-c9de-44ee-a3a7-329e88a00ffc/.default

# =============================================================================
# Agentic User Authorization
# =============================================================================
AGENTAPPLICATION__USERAUTHORIZATION__HANDLERS__AGENTIC__SETTINGS__TYPE=AgenticUserAuthorization
AGENTAPPLICATION__USERAUTHORIZATION__HANDLERS__AGENTIC__SETTINGS__ALT_BLUEPRINT_NAME=SERVICE_CONNECTION
AGENTAPPLICATION__USERAUTHORIZATION__HANDLERS__AGENTIC__SETTINGS__SCOPES=https://graph.microsoft.com/.default

CONNECTIONSMAP__0__SERVICEURL=*
CONNECTIONSMAP__0__CONNECTION=SERVICE_CONNECTION

# =============================================================================
# Authentication Handler
# =============================================================================
# Set to "AGENTIC" for production (Teams/M365 with agentic token exchange).
# Leave empty for local emulator testing (agentsplayground -c emulator).
AUTH_HANDLER_NAME=AGENTIC

# =============================================================================
# Observability (stamped by 'a365 setup all')
# =============================================================================
ENABLE_A365_OBSERVABILITY_EXPORTER=true
AGENT365OBSERVABILITY__AGENTID=<<YOUR_AGENT_IDENTITY_ID>>
AGENT365OBSERVABILITY__AGENTNAME=<<YOUR_AGENT_IDENTITY_NAME>>
AGENT365OBSERVABILITY__AGENTDESCRIPTION=<<YOUR_AGENT_DESCRIPTION>>
AGENT365OBSERVABILITY__TENANTID=<<YOUR_TENANT_ID>>
AGENT365OBSERVABILITY__AGENTBLUEPRINTID=<<YOUR_BLUEPRINT_ID>>
AGENT365OBSERVABILITY__CLIENTID=<<YOUR_BLUEPRINT_ID>>
AGENT365OBSERVABILITY__CLIENTSECRET=<<YOUR_CLIENT_SECRET>>

# =============================================================================
# MCP Tooling
# =============================================================================
# For local development, use 'a365 develop get-token' to acquire a short-lived
# bearer token for MCP server access. In production, the agentic auth handler
# exchanges tokens automatically.
# BEARER_TOKEN=

# Set to "true" to use agentic auth for MCP servers (production).
# Set to "false" to use BEARER_TOKEN (local development).
USE_AGENTIC_AUTH=true

# =============================================================================
# Server Configuration
# =============================================================================
PORT=3978
LOG_LEVEL=INFO
