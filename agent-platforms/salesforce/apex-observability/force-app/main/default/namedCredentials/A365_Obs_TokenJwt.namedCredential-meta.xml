<?xml version="1.0" encoding="UTF-8"?>
<!--
  Named Credential for FMI Hop 3 (JWT-bearer client-assertion).
  SAME endpoint as Hop 1/2 but NO Authorization header: Hop 3 authenticates with the
  client_assertion (T1) in the body. generateAuthorizationHeader=false ensures SF adds no
  Authorization header. Apex calls: callout:A365_Obs_TokenJwt/{tenantId}/oauth2/v2.0/token
-->
<NamedCredential xmlns="http://soap.sforce.com/2006/04/metadata">
    <allowMergeFieldsInBody>false</allowMergeFieldsInBody>
    <allowMergeFieldsInHeader>false</allowMergeFieldsInHeader>
    <generateAuthorizationHeader>false</generateAuthorizationHeader>
    <label>A365 Obs Token JWT</label>
    <namedCredentialType>SecuredEndpoint</namedCredentialType>
    <namedCredentialParameters>
        <parameterName>Url</parameterName>
        <parameterType>Url</parameterType>
        <parameterValue>https://login.microsoftonline.com</parameterValue>
    </namedCredentialParameters>
    <namedCredentialParameters>
        <externalCredential>A365_Obs_Entra</externalCredential>
        <parameterName>ExternalCredential</parameterName>
        <parameterType>Authentication</parameterType>
    </namedCredentialParameters>
</NamedCredential>
