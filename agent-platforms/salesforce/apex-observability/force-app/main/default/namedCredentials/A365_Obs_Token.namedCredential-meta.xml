<?xml version="1.0" encoding="UTF-8"?>
<!--
  Named Credential for FMI Hop 1/2 (blueprint client-credentials + fmi_path).
  Injects the blueprint client_secret_basic as an Authorization header from the External
  Credential (so the secret never appears in Apex or git). Apex calls:
      callout:A365_Obs_Token/{tenantId}/oauth2/v2.0/token
  - allowMergeFieldsInHeader=true     -> evaluates {!$Credential...} in the header.
  - generateAuthorizationHeader=false -> SF does not manage/override the Authorization header.
-->
<NamedCredential xmlns="http://soap.sforce.com/2006/04/metadata">
    <allowMergeFieldsInBody>false</allowMergeFieldsInBody>
    <allowMergeFieldsInHeader>true</allowMergeFieldsInHeader>
    <generateAuthorizationHeader>false</generateAuthorizationHeader>
    <label>A365 Obs Token</label>
    <namedCredentialType>SecuredEndpoint</namedCredentialType>
    <namedCredentialParameters>
        <parameterName>Url</parameterName>
        <parameterType>Url</parameterType>
        <parameterValue>https://login.microsoftonline.com</parameterValue>
    </namedCredentialParameters>
    <namedCredentialParameters>
        <externalCredential>A365_Obs_Entra</externalCredential>
        <parameterName>ExternalCredential</parameterName>
        <parameterType>Authentication</parameterType>
    </namedCredentialParameters>
    <namedCredentialParameters>
        <parameterName>Authorization</parameterName>
        <parameterType>HttpHeader</parameterType>
        <parameterValue>Basic {!$Credential.A365_Obs_Entra.BlueprintBasicAuth}</parameterValue>
        <sequenceNumber>1</sequenceNumber>
    </namedCredentialParameters>
</NamedCredential>
