<?xml version="1.0" encoding="UTF-8"?>
<!--
  Named Credential for the Agent 365 Observability ingest endpoint.
  No stored auth: the agent-bound Bearer token is set per-call by Apex (from Hop 3).
  generateAuthorizationHeader=false is REQUIRED so SF does not manage/override the
  Apex-set "Authorization: Bearer <token>" header. Apex calls:
      callout:A365_Obs_Ingest/observabilityService/tenants/{tenantId}/otlp/agents/{agentId}/traces?api-version=1
-->
<NamedCredential xmlns="http://soap.sforce.com/2006/04/metadata">
    <allowMergeFieldsInBody>false</allowMergeFieldsInBody>
    <allowMergeFieldsInHeader>false</allowMergeFieldsInHeader>
    <generateAuthorizationHeader>false</generateAuthorizationHeader>
    <label>A365 Obs Ingest</label>
    <namedCredentialType>SecuredEndpoint</namedCredentialType>
    <namedCredentialParameters>
        <parameterName>Url</parameterName>
        <parameterType>Url</parameterType>
        <parameterValue>https://agent365.svc.cloud.microsoft</parameterValue>
    </namedCredentialParameters>
    <namedCredentialParameters>
        <externalCredential>A365_Obs_Entra</externalCredential>
        <parameterName>ExternalCredential</parameterName>
        <parameterType>Authentication</parameterType>
    </namedCredentialParameters>
</NamedCredential>
